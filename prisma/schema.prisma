// Prisma schema for hospital management system

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum PatientStatus {
  ADMITED
  DECEASED
  OUTPATIENT
}

// patient model with extended fields
model Patient {
  id                    String        @id @default(uuid())
  patientId             String?       @unique
  title                 String?
  cardNo                String?
  surname               String?
  firstName             String?
  otherName             String?
  dob                   DateTime?
  gender                String?
  maritalStatus         String?
  nationality           String?
  stateOfOrigin         String?
  lga                   String?
  town                  String?
  permanentAddress      String?
  religion              String?
  email                 String?       @unique
  preferredLanguage     String?
  phoneNumber           String?       @unique
  addressOfResidence    String?
  profession            String?
  nextOfKinName         String?
  nextOfKinPhone        String?
  nextOfKinAddress      String?
  nextOfKinRelationship String?
  hmo                   String?
  fingerprintData       String?
  status                PatientStatus @default(OUTPATIENT)

  appointments     Appointment[]
  admissions       Admission[]
  payments         Payment[]
  wallet           PatientWallet?
  medicalHistories MedicalHistory[]
  doctorReports    DoctorReport[]
  labReports       LabReport[]
  radiologyReports RadiologyReport[]
  prescriptions    Prescription[]
  invoice          Invoice[]
  patientVitals    PatientVitals[]
  allergies        PatientAllergy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy       Staff            @relation("PatientCreatedBy", fields: [createdById], references: [id])
  createdById     String
  updatedBy       Staff?           @relation("PatientUpdatedBy", fields: [updatedById], references: [id])
  updatedById     String?
  waitingPatients WaitingPatient[]
  encounters      Encounter[]
  labRequests     LabRequest[]

  wardId String?
  ward   Ward?   @relation(fields: [wardId], references: [id])

  pregnancies               Pregnancy[]
  babiesAsMother            Baby[]
  babiesRegisteredAsPatient Baby[]            @relation("BabyRegisteredPatient")
  gynaeProcedures           GynaeProcedure[]
  postnatalVisitsAsSubject  PostnatalVisit[]
  labOrders                 LabOrder[]
  radiologyOrders           RadiologyOrder[]
  medicationOrders          MedicationOrder[]
}

// ─── ICD-10 (optional: for diagnosis tab search; or use external API) ───────────

model Icd10Code {
  id          String    @id @default(uuid())
  code        String    @unique
  description String
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([code])
  @@index([description])
}

model Appointment {
  id        String   @id @default(uuid())
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
  date      DateTime
  status    String
  notes     String?
  createdAt DateTime @default(now())
  staffId   String?
  staff     Staff?   @relation(fields: [staffId], references: [id])

  encounters Encounter[]

  createdBy   Staff   @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Admission {
  id            String     @id @default(uuid())
  patient       Patient    @relation(fields: [patientId], references: [id])
  patientId     String
  encounter     Encounter? @relation("AdmissionEncounter")
  admissionDate DateTime
  dischargeDate DateTime?
  ward          String?
  room          String?
  reason        String?
  createdAt     DateTime   @default(now())

  // Enhanced inpatient structure (keep legacy fields above for compatibility)
  admissionDateTime  DateTime        @default(now())
  admittedByDoctor   Staff?          @relation("AdmissionAdmittedByDoctor", fields: [admittedByDoctorId], references: [id])
  admittedByDoctorId String?
  wardEntity         Ward?           @relation("WardAdmissions", fields: [wardId], references: [id])
  wardId             String?
  bed                Bed?            @relation("BedAdmissions", fields: [bedId], references: [id])
  bedId              String?
  primaryDiagnosis   String?
  admissionReason    String?
  admissionType      AdmissionType?
  status             AdmissionStatus @default(ACTIVE)
  dischargeDateTime  DateTime?
  dischargeSummary   String?
  outcome            String?

  nurseAssignments          NurseAssignment[]
  medicationOrders          AdmissionMedicationOrder[]
  medicationAdministrations MedicationAdministration[]
  ivFluidOrders             IVFluidOrder[]
  ivMonitorings             IVMonitoring[]
  intakeOutputRecords       IntakeOutputRecord[]
  nursingNotes              NursingNote[]
  procedureRecords          ProcedureRecord[]
  woundAssessments          WoundAssessment[]
  carePlans                 CarePlan[]
  monitoringCharts          MonitoringChart[]
  handoverReports           HandoverReport[]
  alerts                    AlertLog[]
  auditTrails               AuditTrail[]
  patientVitals             PatientVitals[]
  wardRoundNotes            WardRoundNote[]
  labourDeliveries          LabourDelivery[]           @relation("AdmissionLabourDeliveries")
  gynaeProcedures           GynaeProcedure[]

  attendingDoctor   Staff?  @relation("AdmissionAttendingDoctor", fields: [attendingDoctorId], references: [id])
  attendingDoctorId String?

  createdBy   Staff   @relation("AdmissionCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("AdmissionUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  @@index([patientId])
  @@index([status])
  @@index([attendingDoctorId])
}

model Payment {
  id          String   @id @default(uuid())
  patient     Patient  @relation(fields: [patientId], references: [id])
  patientId   String
  amount      Float
  method      String
  description String?
  date        DateTime @default(now())

  createdBy   Staff   @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("PaymentUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
  bank        Bank?   @relation(fields: [bankId], references: [id])
  bankId      String?
}

model MedicalHistory {
  id        String   @id @default(uuid())
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
  details   String
  createdAt DateTime @default(now())

  createdBy   Staff   @relation("MedicalHistoryCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("MedicalHistoryUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model DoctorReport {
  id          String     @id @default(uuid())
  patient     Patient    @relation(fields: [patientId], references: [id])
  patientId   String
  encounter   Encounter? @relation(fields: [encounterId], references: [id])
  encounterId String?
  doctorId    String?
  report      String
  createdAt   DateTime   @default(now())

  createdBy   Staff   @relation("DoctorReportCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("DoctorReportUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model LabReport {
  id          String     @id @default(uuid())
  patient     Patient    @relation(fields: [patientId], references: [id])
  patientId   String
  encounter   Encounter? @relation(fields: [encounterId], references: [id])
  encounterId String?
  reportType  String
  results     String
  date        DateTime   @default(now())

  createdBy   Staff   @relation("LabReportCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("LabReportUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model RadiologyReport {
  id          String     @id @default(uuid())
  patient     Patient    @relation(fields: [patientId], references: [id])
  patientId   String
  encounter   Encounter? @relation(fields: [encounterId], references: [id])
  encounterId String?
  reportType  String
  results     String
  date        DateTime   @default(now())

  createdBy   Staff   @relation("RadiologyReportCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("RadiologyReportUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Prescription {
  id          String     @id @default(uuid())
  patient     Patient    @relation(fields: [patientId], references: [id])
  patientId   String
  encounter   Encounter? @relation(fields: [encounterId], references: [id])
  encounterId String?
  // Legacy simple fields (kept nullable for backward compatibility)
  drug        String?
  dosage      String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?

  // Pharmacy domain extensions
  type     PrescriptionType   @default(OUTPATIENT)
  status   PrescriptionStatus @default(PENDING)
  doctor   Staff?             @relation("PrescriptionDoctor", fields: [doctorId], references: [id])
  doctorId String?

  items         PrescriptionItem[]
  dispensations Dispensation[]

  createdBy   Staff   @relation("PrescriptionCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("PrescriptionUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

// ─────────────────────────────────────────────────────────────────────────────
// PHARMACY DOMAIN
// ─────────────────────────────────────────────────────────────────────────────

enum PharmacyLocationType {
  STORE
  DISPENSARY
}

enum InventoryMovementType {
  PURCHASE
  TRANSFER_OUT
  TRANSFER_IN
  DISPENSE
  ADJUSTMENT
  RETURN
  EXPIRY_WRITEOFF
}

enum MovementReferenceType {
  PURCHASE_ORDER
  TRANSFER
  DISPENSATION
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  CANCELLED
}

enum StockTransferStatus {
  PENDING
  APPROVED
  COMPLETED
}

enum PrescriptionType {
  OUTPATIENT
  INPATIENT
}

enum PrescriptionStatus {
  PENDING
  PARTIALLY_DISPENSED
  COMPLETED
  CANCELLED
}

enum DispensationStatus {
  DRAFT
  COMPLETED
  REVERSED
}

enum PrescriptionItemType {
  DRUG
  CONSUMABLE
}

model Manufacturer {
  id          String   @id @default(uuid())
  name        String
  country     String?
  contactInfo Json?
  createdAt   DateTime @default(now())

  drugs Drug[]
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  licenseNumber String?
  contactInfo   Json?
  creditTerms   String?
  leadTimeDays  Int?
  rating        Int?
  isBlacklisted Boolean  @default(false)
  createdAt     DateTime @default(now())

  batches        DrugBatch[]
  purchaseOrders PurchaseOrder[]
}

model Drug {
  id               String        @id @default(uuid())
  genericName      String
  searviceCode     String
  brandName        String
  strength         String?
  dosageForm       String?
  route            String?
  therapeuticClass String?
  atcCode          String?
  manufacturer     Manufacturer? @relation(fields: [manufacturerId], references: [id])
  manufacturerId   String?
  isControlled     Boolean       @default(false)
  isRefrigerated   Boolean       @default(false)
  isHighAlert      Boolean       @default(false)
  maxDailyDose     Decimal?      @db.Decimal(10, 2)
  reorderLevel     Int           @default(0)
  reorderQuantity  Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  batches            DrugBatch[]
  interactionsA      DrugInteraction[]   @relation("DrugInteractionA")
  interactionsB      DrugInteraction[]   @relation("DrugInteractionB")
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  prescriptionItems  PrescriptionItem[]
  inventoryMovements InventoryMovement[]

  createdBy        Staff             @relation("DrugCreatedBy", fields: [createdById], references: [id])
  createdById      String
  updatedBy        Staff?            @relation("DrugUpdatedBy", fields: [updatedById], references: [id])
  updatedById      String?
  medicationOrders MedicationOrder[]
  invoiceItems     InvoiceItem[]
  drugPrices       DrugPrice[]

  @@index([manufacturerId])
  @@index([isControlled])
}

model DrugPrice {
  id        String   @id @default(uuid())
  drug      Drug     @relation(fields: [drugId], references: [id])
  drugId    String
  ward      Ward     @relation(fields: [wardId], references: [id])
  wardId    String
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([drugId, wardId])
}

model DrugInteraction {
  id       String @id @default(uuid())
  drugA    Drug   @relation("DrugInteractionA", fields: [drugAId], references: [id])
  drugAId  String
  drugB    Drug   @relation("DrugInteractionB", fields: [drugBId], references: [id])
  drugBId  String
  severity String

  @@unique([drugAId, drugBId])
}

model Consumable {
  id           String   @id @default(uuid())
  name         String
  category     String?
  reorderLevel Int?
  isBillable   Boolean  @default(true)
  createdAt    DateTime @default(now())

  batches           ConsumableBatch[]
  prescriptionItems PrescriptionItem[]
  movements         ConsumableMovement[]
}

model DrugBatch {
  id                String           @id @default(uuid())
  drug              Drug             @relation(fields: [drugId], references: [id])
  drugId            String
  fromLocation      PharmacyLocation @relation("DrugBatchFromLocation", fields: [fromLocationId], references: [id])
  fromLocationId    String
  toLocation        PharmacyLocation @relation("DrugBatchToLocation", fields: [toLocationId], references: [id])
  toLocationId      String
  batchNumber       String
  manufacturingDate DateTime
  expiryDate        DateTime
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId        String?
  costPrice         Decimal          @db.Decimal(12, 2)
  sellingPrice      Decimal          @db.Decimal(12, 2)
  quantityReceived  Int
  quantityRemaining Int
  grn               GoodsReceipt?    @relation(fields: [grnId], references: [id])
  grnId             String?
  createdAt         DateTime         @default(now())

  movements         InventoryMovement[]
  transferItems     StockTransferItem[]
  dispensationItems DispensationItem[]

  @@index([drugId, fromLocationId, toLocationId])
  @@index([expiryDate])
  @@index([supplierId])
  @@index([manufacturingDate])
}

model InventoryMovement {
  id             String                @id @default(uuid())
  batch          DrugBatch             @relation(fields: [batchId], references: [id])
  batchId        String
  drug           Drug                  @relation(fields: [drugId], references: [id])
  drugId         String
  fromLocation   PharmacyLocation      @relation("InventoryMovementFromLocation", fields: [fromLocationId], references: [id])
  fromLocationId String
  toLocation     PharmacyLocation      @relation("InventoryMovementToLocation", fields: [toLocationId], references: [id])
  toLocationId   String
  movementType   InventoryMovementType
  quantity       Int
  referenceType  MovementReferenceType
  referenceId    String
  performedBy    Staff                 @relation("InventoryMovementPerformedBy", fields: [performedById], references: [id])
  performedById  String
  createdAt      DateTime              @default(now())
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Decimal             @db.Decimal(12, 2)
  createdBy    Staff               @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  createdById  String
  approvedBy   Staff?              @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id])
  approvedById String?
  createdAt    DateTime            @default(now())

  items    PurchaseOrderItem[]
  receipts GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  drug            Drug          @relation(fields: [drugId], references: [id])
  drugId          String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)
  expectedExpiry  DateTime?
}

model GoodsReceipt {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  receivedBy      Staff         @relation("GoodsReceiptReceivedBy", fields: [receivedById], references: [id])
  receivedById    String
  receivedAt      DateTime      @default(now())

  items   GoodsReceiptItem[]
  batches DrugBatch[]
}

model GoodsReceiptItem {
  id                String       @id @default(uuid())
  goodsReceipt      GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  goodsReceiptId    String
  drug              Drug         @relation(fields: [drugId], references: [id])
  drugId            String
  batchNumber       String
  manufacturingDate DateTime
  expiryDate        DateTime
  quantityReceived  Int
  costPrice         Decimal      @db.Decimal(12, 2)
}

model StockTransfer {
  id             String           @id @default(uuid())
  fromLocation   PharmacyLocation @relation("StockTransferFromLocation", fields: [fromLocationId], references: [id])
  fromLocationId String
  toLocation     PharmacyLocation @relation("StockTransferToLocation", fields: [toLocationId], references: [id])
  toLocationId   String

  status       StockTransferStatus @default(PENDING)
  createdBy    Staff               @relation("StockTransferCreatedBy", fields: [createdById], references: [id])
  createdById  String
  approvedBy   Staff?              @relation("StockTransferApprovedBy", fields: [approvedById], references: [id])
  approvedById String?
  createdAt    DateTime            @default(now())
  completedAt  DateTime?

  items StockTransferItem[]
}

model StockTransferItem {
  id              String        @id @default(uuid())
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id])
  stockTransferId String
  batch           DrugBatch     @relation(fields: [batchId], references: [id])
  batchId         String
  quantity        Int
}

model PrescriptionItem {
  id                 String               @id @default(uuid())
  prescription       Prescription         @relation(fields: [prescriptionId], references: [id])
  prescriptionId     String
  itemType           PrescriptionItemType
  drug               Drug?                @relation(fields: [drugId], references: [id])
  drugId             String?
  consumable         Consumable?          @relation(fields: [consumableId], references: [id])
  consumableId       String?
  dosage             String
  frequency          String?
  duration           Int?
  quantityPrescribed Int
  quantityDispensed  Int                  @default(0)
  instructions       String?

  dispensationItems DispensationItem[]

  @@index([prescriptionId])
  @@index([drugId])
}

model PharmacyLocation {
  id                     String               @id @default(uuid())
  name                   String
  locationType           PharmacyLocationType
  description            String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdBy              Staff                @relation("PharmacyLocationCreatedBy", fields: [createdById], references: [id])
  createdById            String
  updatedBy              Staff?               @relation("PharmacyLocationUpdatedBy", fields: [updatedById], references: [id])
  updatedById            String?
  drugBatchesFrom        DrugBatch[]          @relation("DrugBatchFromLocation")
  drugBatchesTo          DrugBatch[]          @relation("DrugBatchToLocation")
  inventoryMovementsFrom InventoryMovement[]  @relation("InventoryMovementFromLocation")
  inventoryMovementsTo   InventoryMovement[]  @relation("InventoryMovementToLocation")
  stockTransfersFrom     StockTransfer[]      @relation("StockTransferFromLocation")
  stockTransfersTo       StockTransfer[]      @relation("StockTransferToLocation")
  dispensations          Dispensation[]
  consumableBatches      ConsumableBatch[]
  consumableMovements    ConsumableMovement[]
  staff                  Staff?               @relation("PharmacyLocationStaff", fields: [staffId], references: [id])
  staffId                String?              @unique
}

model Dispensation {
  id             String               @id @default(uuid())
  prescription   Prescription         @relation(fields: [prescriptionId], references: [id])
  prescriptionId String
  location       PharmacyLocation     @relation(fields: [locationId], references: [id])
  locationId     String
  locationType   PharmacyLocationType @default(DISPENSARY)
  pharmacist     Staff                @relation("DispensationPharmacist", fields: [pharmacistId], references: [id])
  pharmacistId   String
  status         DispensationStatus   @default(DRAFT)
  createdAt      DateTime             @default(now())

  items     DispensationItem[]
  approvals ControlledApproval[]
}

model DispensationItem {
  id                 String           @id @default(uuid())
  dispensation       Dispensation     @relation(fields: [dispensationId], references: [id])
  dispensationId     String
  prescriptionItem   PrescriptionItem @relation(fields: [prescriptionItemId], references: [id])
  prescriptionItemId String
  batch              DrugBatch?       @relation(fields: [batchId], references: [id])
  batchId            String?
  quantityDispensed  Int
}

model ControlledApproval {
  id             String       @id @default(uuid())
  dispensation   Dispensation @relation(fields: [dispensationId], references: [id])
  dispensationId String
  approver       Staff        @relation("ControlledApprovalApprover", fields: [approverId], references: [id])
  approverId     String
  approvedAt     DateTime     @default(now())
}

model ConsumableBatch {
  id                String               @id @default(uuid())
  consumable        Consumable           @relation(fields: [consumableId], references: [id])
  consumableId      String
  locationType      PharmacyLocationType
  location          PharmacyLocation     @relation(fields: [locationId], references: [id])
  locationId        String
  batchNumber       String?
  expiryDate        DateTime?
  quantityReceived  Int
  quantityRemaining Int
  createdAt         DateTime             @default(now())

  movements ConsumableMovement[]

  @@index([consumableId, locationType])
}

model ConsumableMovement {
  id            String                @id @default(uuid())
  batch         ConsumableBatch       @relation(fields: [batchId], references: [id])
  batchId       String
  consumable    Consumable            @relation(fields: [consumableId], references: [id])
  consumableId  String
  locationType  PharmacyLocationType
  movementType  InventoryMovementType
  location      PharmacyLocation      @relation(fields: [locationId], references: [id])
  locationId    String
  quantity      Int
  referenceType MovementReferenceType
  referenceId   String
  performedBy   Staff                 @relation("ConsumableMovementPerformedBy", fields: [performedById], references: [id])
  performedById String
  createdAt     DateTime              @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  entity        String
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  performedBy   Staff?   @relation("AuditLogPerformedBy", fields: [performedById], references: [id])
  performedById String?
  createdAt     DateTime @default(now())
}

model ServiceCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  location    String?

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   Staff   @relation("ServiceCategoryCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("ServiceCategoryUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Service {
  id           String           @id @default(uuid())
  name         String
  description  String?
  searviceCode String
  cost         Float // or Decimal if you really need precision
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  categoryId   String?
  department   Department?      @relation(fields: [departmentId], references: [id])
  departmentId String?

  createdBy   Staff   @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("ServiceUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceItems InvoiceItem[]

  waitingPatients WaitingPatient[]
}

model Invoice {
  id          String        @id @default(uuid())
  invoiceID   String        @unique
  patient     Patient       @relation(fields: [patientId], references: [id])
  patientId   String
  status      InvoiceStatus @default(PENDING)
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @db.Decimal(12, 2)
  createdBy   Staff         @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?        @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  invoiceItems    InvoiceItem[]
  payments        InvoicePayment[]
  refunds         InvoiceRefund[]
  walletTxns      WalletTransaction[]
  insuranceClaims InsuranceClaim[]
  auditLogs       InvoiceAuditLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  staff           Staff               @relation(fields: [staffId], references: [id])
  staffId         String

  encounter        Encounter?      @relation(fields: [encounterId], references: [id])
  encounterId      String?
  consultingRoom   ConsultingRoom? @relation(fields: [consultingRoomId], references: [id], onDelete: SetNull)
  consultingRoomId String?
  vitals           PatientVitals?  @relation("InvoiceVitals", fields: [vitalsId], references: [id], onDelete: SetNull)
  vitalsId         String?         @unique
  labRequests      LabRequest[]

  @@index([patientId])
  @@index([invoiceID])
  @@index([createdById])
  @@index([updatedById])
  @@index([staffId])
  @@index([encounterId])
  @@index([consultingRoomId])
}

model InvoiceItem {
  id        String   @id @default(uuid())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  service   Service? @relation(fields: [serviceId], references: [id])
  serviceId String?
  settled   Boolean  @default(false)

  drug   Drug?   @relation(fields: [drugId], references: [id])
  drugId String?

  customDescription String?
  createdBy         Staff?  @relation("InvoiceItemCreatedBy", fields: [createdById], references: [id])
  createdById       String?

  quantity           Int                       @default(1)
  unitPrice          Decimal                   @default(0) @db.Decimal(12, 2)
  amountPaid         Decimal                   @default(0) @db.Decimal(12, 2)
  isRecurringDaily   Boolean                   @default(false)
  usageSegments      InvoiceItemUsageSegment[]
  allocations        InvoiceItemPayment[]
  radiologyOrderItem RadiologyOrderItem?
  labOrder           LabOrder?
  labRequest         LabRequest?

  @@index([invoiceId])
}

model InvoiceItemPayment {
  id               String          @id @default(uuid())
  invoiceItem      InvoiceItem     @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  invoiceItemId    String
  invoicePayment   InvoicePayment? @relation(fields: [invoicePaymentId], references: [id], onDelete: Cascade)
  invoicePaymentId String?
  amount           Decimal         @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())

  @@index([invoiceItemId])
  @@index([invoicePaymentId])
}

model InvoiceItemUsageSegment {
  id            String      @id @default(uuid())
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  invoiceItemId String
  startAt       DateTime
  endAt         DateTime?
  createdAt     DateTime    @default(now())

  @@index([invoiceItemId, startAt])
  @@index([invoiceItemId, endAt])
}

model PatientWallet {
  id           String              @id @default(uuid())
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId    String              @unique
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  transactions WalletTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model WalletTransaction {
  id          String                @id @default(uuid())
  wallet      PatientWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId    String
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(12, 2)
  reference   String
  invoice     Invoice?              @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceId   String?
  createdBy   Staff?                @relation("WalletTransactionCreatedBy", fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime              @default(now())
  payment     InvoicePayment?

  @@index([walletId, createdAt])
  @@index([invoiceId])
}

model InvoicePayment {
  id                  String                @id @default(uuid())
  invoice             Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId           String
  amount              Decimal               @db.Decimal(12, 2)
  source              InvoicePaymentSource
  method              InvoicePaymentMethod?
  reference           String?
  notes               String?
  receivedBy          Staff?                @relation("InvoicePaymentReceivedBy", fields: [receivedById], references: [id])
  receivedById        String?
  bank                Bank?                 @relation(fields: [bankId], references: [id])
  bankId              String?
  createdBy           Staff?                @relation("InvoicePaymentCreatedBy", fields: [createdById], references: [id])
  createdById         String?
  paidAt              DateTime              @default(now())
  walletTransaction   WalletTransaction?    @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)
  walletTransactionId String?               @unique
  itemAllocations     InvoiceItemPayment[]
  createdAt           DateTime              @default(now())

  @@index([invoiceId, createdAt])
  @@index([paidAt])
}

model InvoiceRefund {
  id            String   @id @default(uuid())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
  amount        Decimal  @db.Decimal(12, 2)
  reason        String
  processedBy   Staff    @relation("InvoiceRefundProcessedBy", fields: [processedById], references: [id])
  processedById String
  createdBy     Staff?   @relation("InvoiceRefundCreatedBy", fields: [createdById], references: [id])
  createdById   String?
  refundedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([invoiceId, refundedAt])
}

model InvoiceAuditLog {
  id            String             @id @default(uuid())
  invoice       Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
  action        InvoiceAuditAction
  description   String
  metadata      Json?
  performedBy   Staff?             @relation("InvoiceAuditLogPerformedBy", fields: [performedById], references: [id])
  performedById String?
  createdAt     DateTime           @default(now())

  @@index([invoiceId, createdAt])
}

