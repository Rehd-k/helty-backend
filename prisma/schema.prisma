model Department {
  id   String @id @default(uuid())
  name String @unique

  head   Staff?  @relation("DepartmentHead", fields: [headId], references: [id])
  headId String? @unique
  staff  Staff[]

  from String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy           Staff                @relation("DepartmentCreatedBy", fields: [createdById], references: [id])
  createdById         String
  updatedBy           Staff?               @relation("DepartmentUpdatedBy", fields: [updatedById], references: [id])
  updatedById         String?
  services            Service[]
  wards               Ward[]
  nurses              Nurse[]
  radiologyOrders     RadiologyOrder[]
  purchaseNotes       PurchaseNote[]
  storeStockMovements StoreStockMovement[]
}

model Staff {
  id           String      @id @default(uuid())
  staffId      String      @unique
  firstName    String
  lastName     String
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?
  accountType  AccountType
  staffRole    StaffRole
  email        String?     @unique
  phone        String?
  password     String?
  isActive     Boolean     @default(true)

  // one-to-one relation for department head
  headedDepartment Department? @relation("DepartmentHead")

  createdBy   Staff?  @relation("StaffCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   Staff?  @relation("StaffUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  patientsCreated          Patient[]         @relation("PatientCreatedBy")
  patientsUpdated          Patient[]         @relation("PatientUpdatedBy")
  appointmentsCreated      Appointment[]     @relation("AppointmentCreatedBy")
  appointmentsUpdated      Appointment[]     @relation("AppointmentUpdatedBy")
  admissionsCreated        Admission[]       @relation("AdmissionCreatedBy")
  admissionsUpdated        Admission[]       @relation("AdmissionUpdatedBy")
  paymentsCreated          Payment[]         @relation("PaymentCreatedBy")
  paymentsUpdated          Payment[]         @relation("PaymentUpdatedBy")
  medicalHistoriesCreated  MedicalHistory[]  @relation("MedicalHistoryCreatedBy")
  medicalHistoriesUpdated  MedicalHistory[]  @relation("MedicalHistoryUpdatedBy")
  doctorReportsCreated     DoctorReport[]    @relation("DoctorReportCreatedBy")
  doctorReportsUpdated     DoctorReport[]    @relation("DoctorReportUpdatedBy")
  labReportsCreated        LabReport[]       @relation("LabReportCreatedBy")
  labReportsUpdated        LabReport[]       @relation("LabReportUpdatedBy")
  radiologyReportsCreated  RadiologyReport[] @relation("RadiologyReportCreatedBy")
  radiologyReportsUpdated  RadiologyReport[] @relation("RadiologyReportUpdatedBy")
  prescriptionsCreated     Prescription[]    @relation("PrescriptionCreatedBy")
  prescriptionsUpdated     Prescription[]    @relation("PrescriptionUpdatedBy")
  servicesCreated          Service[]         @relation("ServiceCreatedBy")
  servicesUpdated          Service[]         @relation("ServiceUpdatedBy")
  serviceCategoriesCreated ServiceCategory[] @relation("ServiceCategoryCreatedBy")
  serviceCategoriesUpdated ServiceCategory[] @relation("ServiceCategoryUpdatedBy")
  invoicesCreated          Invoice[]         @relation("InvoiceCreatedBy")
  invoicesUpdated          Invoice[]         @relation("InvoiceUpdatedBy")
  departmentsCreated       Department[]      @relation("DepartmentCreatedBy")
  departmentsUpdated       Department[]      @relation("DepartmentUpdatedBy")
  staffCreated             Staff[]           @relation("StaffCreatedBy")
  staffUpdated             Staff[]           @relation("StaffUpdatedBy")

  insuranceClaimsCreated InsuranceClaim[] @relation("InsuranceClaimCreatedBy")
  insuranceClaimsUpdated InsuranceClaim[] @relation("InsuranceClaimUpdatedBy")
  invoices               Invoice[]
  banksCreated           Bank[]           @relation("BankCreatedBy")
  banksUpdated           Bank[]           @relation("BankUpdatedBy")
  banks                  Bank[]
  consultingRooms        ConsultingRoom[]
  waitingPatients        WaitingPatient[]
  consultingRoomsCreated ConsultingRoom[] @relation("ConsultingRoomCreatedBy")
  consultingRoomsUpdated ConsultingRoom[] @relation("ConsultingRoomUpdatedBy")
  waitingPatientsCreated WaitingPatient[] @relation("WaitingPatientCreatedBy")
  waitingPatientsUpdated WaitingPatient[] @relation("WaitingPatientUpdatedBy")

  admissionsAdmitted                  Admission[]                @relation("AdmissionAdmittedByDoctor")
  admissionMedicationOrdersPrescribed AdmissionMedicationOrder[] @relation("AdmissionMedicationOrderPrescribedBy")
  ivFluidOrdersOrdered                IVFluidOrder[]
  auditTrailsPerformed                AuditTrail[]
  nurse                               Nurse?
  alertLogs                           AlertLog[]
  encountersAsDoctor                  Encounter[]                @relation("EncounterDoctor")
  encountersCreated                   Encounter[]                @relation("EncounterCreatedBy")
  encountersUpdated                   Encounter[]                @relation("EncounterUpdatedBy")
  labRequestsOrdered                  LabRequest[]               @relation("LabRequestOrderedBy")
  radiologyOrdersRequested            RadiologyOrder[]           @relation("RadiologyOrderOrderedBy")
  prescriptionsAsDoctor               Prescription[]             @relation("PrescriptionDoctor")
  purchaseOrdersCreated               PurchaseOrder[]            @relation("PurchaseOrderCreatedBy")
  purchaseOrdersApproved              PurchaseOrder[]            @relation("PurchaseOrderApprovedBy")
  goodsReceiptsReceived               GoodsReceipt[]             @relation("GoodsReceiptReceivedBy")
  stockTransfersCreated               StockTransfer[]            @relation("StockTransferCreatedBy")
  stockTransfersApproved              StockTransfer[]            @relation("StockTransferApprovedBy")
  drugsCreated                        Drug[]                     @relation("DrugCreatedBy")
  drugsUpdated                        Drug[]                     @relation("DrugUpdatedBy")
  inventoryMovementsPerformed         InventoryMovement[]        @relation("InventoryMovementPerformedBy")
  consumableMovementsPerformed        ConsumableMovement[]       @relation("ConsumableMovementPerformedBy")
  dispensationsAsPharmacist           Dispensation[]             @relation("DispensationPharmacist")
  controlledApprovals                 ControlledApproval[]       @relation("ControlledApprovalApprover")
  auditLogsPerformed                  AuditLog[]                 @relation("AuditLogPerformedBy")
  pharmacyLocationsCreated            PharmacyLocation[]         @relation("PharmacyLocationCreatedBy")
  pharmacyLocationsUpdated            PharmacyLocation[]         @relation("PharmacyLocationUpdatedBy")
  pharmacyLocationAssigned            PharmacyLocation?          @relation("PharmacyLocationStaff")
  admissionsAsAttendingDoctor         Admission[]                @relation("AdmissionAttendingDoctor")
  wardRoundNotes                      WardRoundNote[]
  pregnanciesCreated                  Pregnancy[]                @relation("PregnancyCreatedBy")
  pregnanciesUpdated                  Pregnancy[]                @relation("PregnancyUpdatedBy")
  antenatalVisitsRecorded             AntenatalVisit[]
  labourDeliveriesDeliveredBy         LabourDelivery[]
  partogramEntriesRecorded            PartogramEntry[]
  babiesCreated                       Baby[]                     @relation("BabyCreatedBy")
  babiesUpdated                       Baby[]                     @relation("BabyUpdatedBy")
  postnatalVisitsRecorded             PostnatalVisit[]
  gynaeProceduresAsSurgeon            GynaeProcedure[]           @relation("GynaeProcedureSurgeon")
  gynaeProceduresAsAssistant          GynaeProcedure[]           @relation("GynaeProcedureAssistant")
  labOrdersAsDoctor                   LabOrder[]                 @relation("LabOrderDoctor")
  labSamplesCollected                 LabSample[]                @relation("LabSampleCollectedBy")
  labResultsEntered                   LabResult[]                @relation("LabResultEnteredBy")
  chatMessagesSent                    ChatMessage[]              @relation("ChatMessageSender")
  chatMessagesReceived                ChatMessage[]              @relation("ChatMessageRecipient")
  radiologySchedulesAsRadiographer    RadiologySchedule[]        @relation("RadiologyScheduleRadiographer")
  radiologyProceduresPerformed        RadiologyProcedure[]       @relation("RadiologyProcedurePerformedBy")
  radiologyImagesUploaded             RadiologyImage[]           @relation("RadiologyImageUploadedBy")
  radiologyReportsSigned              RadiologyStudyReport[]     @relation("RadiologyReportSignedBy")
  medicationOrders                    MedicationOrder[]
  purchaseNotesRequested              PurchaseNote[]             @relation("PurchaseNoteRequestedBy")
  storeStockMovementsCreated          StoreStockMovement[]       @relation("StoreStockMovementCreatedBy")
  invoiceItemsCreated                 InvoiceItem[]              @relation("InvoiceItemCreatedBy")
  invoicePaymentsReceived             InvoicePayment[]           @relation("InvoicePaymentReceivedBy")
  invoicePaymentsCreated              InvoicePayment[]           @relation("InvoicePaymentCreatedBy")
  invoiceRefundsProcessed             InvoiceRefund[]            @relation("InvoiceRefundProcessedBy")
  invoiceRefundsCreated               InvoiceRefund[]            @relation("InvoiceRefundCreatedBy")
  walletTransactionsCreated           WalletTransaction[]        @relation("WalletTransactionCreatedBy")
  invoiceAuditLogsPerformed           InvoiceAuditLog[]          @relation("InvoiceAuditLogPerformedBy")
}

enum ChatMessageStatus {
  SENT
  DELIVERED
  READ
}

model ChatMessage {
  id          String            @id @default(uuid())
  sender      Staff             @relation("ChatMessageSender", fields: [senderId], references: [id])
  senderId    String
  recipient   Staff             @relation("ChatMessageRecipient", fields: [recipientId], references: [id])
  recipientId String
  content     String
  status      ChatMessageStatus @default(SENT)
  createdAt   DateTime          @default(now())
}

// Encounter: clinical anchor for every doctor interaction (outpatient, emergency, inpatient review, etc.)
// Merged with OPD/visit fields and orders (medication, lab, imaging).
model Encounter {
  id             String          @id @default(uuid())
  patient        Patient         @relation(fields: [patientId], references: [id])
  patientId      String
  doctor         Staff           @relation("EncounterDoctor", fields: [doctorId], references: [id])
  doctorId       String
  admission      Admission?      @relation("AdmissionEncounter", fields: [admissionId], references: [id])
  admissionId    String?         @unique
  appointment    Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  appointmentId  String?
  encounterType  EncounterType
  startTime      DateTime
  endTime        DateTime?
  chiefComplaint String?
  triageNotes    String?
  status         EncounterStatus @default(ONGOING)

  // OPD / visit context
  visitType              String? // OPD, Walk-in, Follow-up
  insurance              String?
  // History
  hpi                    String?
  pmh                    String?
  surgicalHistory        String?
  drugHistory            String?
  allergyHistory         String?
  familyHistory          String?
  socialHistory          String?
  // Examination & SOAP
  examinationNotes       String?
  soapSubjective         String?
  soapObjective          String?
  soapAssessment         String?
  soapPlan               String?
  soapLockedAt           DateTime?
  // Diagnosis (structured use EncounterDiagnosis; these for quick/legacy)
  primaryIcdCode         String?
  primaryIcdDescription  String?
  secondaryDiagnosesJson String? // JSON array of { code, description }
  proceduresJson         String? // JSON array of { type, consent, notes, complications }
  // Follow-up
  followUpDate           String?
  followUpInstructions   String?
  referral               String?

  doctorReports    DoctorReport[]
  prescriptions    Prescription[]
  labReports       LabReport[]
  radiologyReports RadiologyReport[]
  diagnoses        EncounterDiagnosis[]
  labRequests      LabRequest[]
  medicationOrders MedicationOrder[]
  legacyLabOrders  LegacyLabOrder[]
  radiologyOrders  RadiologyOrder[]
  antenatalVisits  AntenatalVisit[]
  gynaeProcedures  GynaeProcedure[]

  createdBy   Staff     @relation("EncounterCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?    @relation("EncounterUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoices    Invoice[]
}

// Structured diagnosis per encounter
model EncounterDiagnosis {
  id                     String    @id @default(uuid())
  encounter              Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId            String
  primaryIcdCode         String?
  primaryIcdDescription  String?
  secondaryDiagnosesJson Json? // JSON array of { code, description }
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// Lab order/request tied to an encounter (before results in LabReport)
model LabRequest {
  id                  String           @id @default(uuid())
  encounter           Encounter        @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId         String
  patient             Patient          @relation(fields: [patientId], references: [id])
  patientId           String
  requestedBy         Staff            @relation("LabRequestOrderedBy", fields: [requestedByDoctorId], references: [id])
  requestedByDoctorId String
  testType            String?
  notes               String?
  status              LabRequestStatus @default(REQUESTED)
  invoice             Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceId           String?
  invoiceItem         InvoiceItem?     @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  invoiceItemId       String?          @unique
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([invoiceId])
}

// InsuranceClaim: insurance coverage applied to an invoice
model InsuranceClaim {
  id            String   @id @default(uuid())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
  provider      String
  policyNumber  String?
  coveredAmount Decimal  @db.Decimal(12, 2)
  status        String   @default("PENDING")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy   Staff?  @relation("InsuranceClaimCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   Staff?  @relation("InsuranceClaimUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  @@index([invoiceId])
}

// Bank: hospital bank accounts that can receive payments
model Bank {
  id            String @id @default(uuid())
  name          String
  accountNumber String @unique

  invoicePayments InvoicePayment[]

  createdBy   Staff?  @relation("BankCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   Staff?  @relation("BankUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
  staff     Staff?    @relation(fields: [staffId], references: [id])
  staffId   String?
}

model PatientVitals {
  id String @id @default(uuid())

  systolic     Int?
  diastolic    Int?
  temperature  Float?
  height       Float?
  weight       Float?
  bmi          Float?
  pulseRate    Int?
  spo2         Float?
  painScore    Int?
  notes        String?
  bloodGlucose Float?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  waitingPatient    WaitingPatient? @relation(fields: [waitingPatientId], references: [id])
  waitingPatientId  String?         @unique
  admission         Admission?      @relation(fields: [admissionId], references: [id])
  admissionId       String?
  patient           Patient?        @relation(fields: [patientId], references: [id])
  patientId         String?
  nurse             Nurse?          @relation(fields: [recordedByNurseId], references: [id])
  recordedByNurseId String?
  invoice           Invoice?        @relation("InvoiceVitals")

  shiftType  ShiftType?
  recordedAt DateTime   @default(now())
