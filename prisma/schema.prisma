model ConsultingRoom {
  id          String   @id @default(uuid())
  name        String
  description String?
  location    String?
  capacity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy       Staff?           @relation("ConsultingRoomCreatedBy", fields: [createdById], references: [id])
  createdById     String?
  updatedBy       Staff?           @relation("ConsultingRoomUpdatedBy", fields: [updatedById], references: [id])
  updatedById     String?
  staff           Staff?           @relation(fields: [staffId], references: [id])
  staffId         String?
  waitingPatients WaitingPatient[]
  invoices        Invoice[]
}

model WaitingPatient {
  id               String          @id @default(uuid())
  patient          Patient         @relation(fields: [patientId], references: [id])
  patientId        String
  consultingRoom   ConsultingRoom? @relation(fields: [consultingRoomId], references: [id])
  consultingRoomId String?
  vitals           PatientVitals?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  service          Service?        @relation(fields: [serviceId], references: [id])
  serviceId        String?
  seen             Boolean         @default(false)

  createdBy   Staff?  @relation("WaitingPatientCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   Staff?  @relation("WaitingPatientUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
  staff       Staff?  @relation(fields: [staffId], references: [id])
  staffId     String?
}

model PatientAllergy {
  id        String  @id @default(uuid())
  patient   Patient @relation(fields: [patientId], references: [id])
  patientId String

  allergen String
  reaction String?
  severity String?
  type     String?
  notes    String?

  createdAt DateTime @default(now())
}

model Ward {
  id           String      @id @default(uuid())
  name         String
  capacity     Int
  type         WardType
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  beds       Bed[]
  admissions Admission[] @relation("WardAdmissions")

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  drugPrices DrugPrice[]
  patients   Patient[]
}

model Bed {
  id        String    @id @default(uuid())
  ward      Ward      @relation(fields: [wardId], references: [id])
  wardId    String
  bedNumber String
  status    BedStatus @default(AVAILABLE)

  admissions Admission[] @relation("BedAdmissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Nurse {
  id      String @id @default(uuid())
  staff   Staff  @relation(fields: [staffId], references: [id])
  staffId String @unique

  licenseNumber String?
  role          String?
  department    Department? @relation(fields: [departmentId], references: [id])
  departmentId  String?
  active        Boolean     @default(true)

  assignments               NurseAssignment[]
  medicationAdministrations MedicationAdministration[]
  ivMonitorings             IVMonitoring[]
  intakeOutputRecords       IntakeOutputRecord[]
  nursingNotes              NursingNote[]
  procedureRecords          ProcedureRecord[]
  woundAssessments          WoundAssessment[]
  carePlans                 CarePlan[]
  monitoringCharts          MonitoringChart[]
  handoverReports           HandoverReport[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  patientVitals PatientVitals[]
}

// ─── Orders (from encounter tabs) ──────────────────────────────────────────────

model DrugCatalog {
  id                String    @id @default(uuid())
  name              String
  generic           String?
  strength          String?
  form              String?
  stockStatus       String?
  contraindications String?
  interactions      String?
  createdAt         DateTime? @default(now())
  updatedAt         DateTime? @updatedAt

  medicationOrders MedicationOrder[]

  @@index([name])
}

model MedicationOrder {
  id                  String    @id @default(uuid())
  encounterId         String
  drugId              String
  drugName            String // denormalized for display
  dose                String?
  frequency           String?
  duration            String?
  route               String?
  specialInstructions String?
  patientId           String
  patient             Patient   @relation(fields: [patientId], references: [id])
  doctorId            String
  doctor              Staff     @relation(fields: [doctorId], references: [id])
  status              String    @default("Pending Dispense") // Pending Dispense, Dispensed, Cancelled
  createdAt           DateTime? @default(now())
  updatedAt           DateTime? @updatedAt

  encounter     Encounter    @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  drug          Drug         @relation(fields: [drugId], references: [id], onDelete: Restrict)
  drugCatalog   DrugCatalog? @relation(fields: [drugCatalogId], references: [id])
  drugCatalogId String?

  @@index([encounterId])
  @@index([patientId])
}

model LegacyLabCatalog {
  id          String    @id @default(uuid())
  name        String
  department  String?
  cost        Float?
  turnaround  String?
  sampleType  String?
  preparation String?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  labOrders LegacyLabOrder[]

  @@index([name])
}

model LegacyLabOrder {
  id            String    @id @default(uuid())
  encounterId   String
  catalogTestId String
  testName      String
  priority      String?   @default("Routine") // Routine, Urgent, STAT
  clinicalNotes String?
  status        String    @default("Ordered") // Ordered, SampleReceived, InProgress, Completed, Cancelled
  resultValues  Json? // { "Hb": "12.5", "WBC": "7.2", ... }
  createdAt     DateTime? @default(now())
  updatedAt     DateTime? @updatedAt

  encounter Encounter        @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  catalog   LegacyLabCatalog @relation(fields: [catalogTestId], references: [id], onDelete: Restrict)

  @@index([encounterId])
}

// ─── Dynamic Lab Module (build-once-use-everywhere) ─────────────────────────

enum LabOrderStatus {
  PENDING
  SAMPLE_COLLECTED
  PROCESSING
  COMPLETED
  VERIFIED
}

enum LabTestFieldType {
  TEXT
  NUMBER
  DROPDOWN
  CHECKBOX
  MULTISELECT
  DATE
}

model LabCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  tests LabTest[]

  @@index([name])
}

model LabTest {
  id          String   @id @default(uuid())
  name        String
  categoryId  String
  sampleType  String // blood, urine, stool, sputum, swab, etc.
  description String?
  price       Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  category LabCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  versions LabTestVersion[]

  @@index([categoryId])
  @@index([isActive])
}

model LabTestVersion {
  id            String   @id @default(uuid())
  testId        String
  versionNumber Int
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())

  test       LabTest        @relation(fields: [testId], references: [id], onDelete: Cascade)
  fields     LabTestField[]
  orderItems LabOrderItem[]

  @@unique([testId, versionNumber])
  @@index([testId])
  @@index([isActive])
}

model LabTestField {
  id             String           @id @default(uuid())
  testVersionId  String
  label          String
  fieldType      LabTestFieldType
  unit           String?
  referenceRange String?
  required       Boolean          @default(false)
  position       Int              @default(0)
  optionsJson    String? // JSON for DROPDOWN/MULTISELECT options
  createdAt      DateTime         @default(now())

  testVersion LabTestVersion @relation(fields: [testVersionId], references: [id], onDelete: Cascade)
  results     LabResult[]

  @@index([testVersionId])
}

model LabOrder {
  id            String         @id @default(uuid())
  patientId     String
  doctorId      String
  status        LabOrderStatus @default(PENDING)
  invoiceItem   InvoiceItem?   @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  invoiceItemId String?        @unique
  createdAt     DateTime       @default(now())

  patient Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor  Staff          @relation("LabOrderDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  items   LabOrderItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([invoiceItemId])
}

model LabOrderItem {
  id            String   @id @default(uuid())
  orderId       String
  testVersionId String
  status        String   @default("PENDING") // PENDING, SAMPLE_COLLECTED, PROCESSING, COMPLETED, VERIFIED
  createdAt     DateTime @default(now())

  order       LabOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testVersion LabTestVersion @relation(fields: [testVersionId], references: [id], onDelete: Restrict)
  sample      LabSample?
  results     LabResult[]

  @@index([orderId])
  @@index([testVersionId])
}

model LabSample {
  id             String   @id @default(uuid())
  orderItemId    String
  sampleType     String
  collectedById  String
  collectionTime DateTime
  barcode        String?
  createdAt      DateTime @default(now())

  orderItem   LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  collectedBy Staff        @relation("LabSampleCollectedBy", fields: [collectedById], references: [id], onDelete: Restrict)

  @@unique([orderItemId])
  @@index([orderItemId])
}

model LabResult {
  id          String   @id @default(uuid())
  orderItemId String
  fieldId     String
  value       String
  enteredById String
  createdAt   DateTime @default(now())

  orderItem LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  field     LabTestField @relation(fields: [fieldId], references: [id], onDelete: Restrict)
  enteredBy Staff        @relation("LabResultEnteredBy", fields: [enteredById], references: [id], onDelete: Restrict)

  @@unique([orderItemId, fieldId])
  @@index([orderItemId])
  @@index([fieldId])
}

model NurseAssignment {
  id          String    @id @default(uuid())
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String

  shiftDate  DateTime
  shiftType  ShiftType
  assignedAt DateTime  @default(now())

  createdAt DateTime @default(now())

  @@unique([nurseId, admissionId, shiftDate, shiftType])
}

model AdmissionMedicationOrder {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String

  prescribedBy         Staff  @relation("AdmissionMedicationOrderPrescribedBy", fields: [prescribedByDoctorId], references: [id])
  prescribedByDoctorId String

  drugName      String
  dose          String
  route         MedicationRoute
  frequency     String
  startDateTime DateTime
  endDateTime   DateTime?
  status        MedicationOrderStatus @default(ACTIVE)
  notes         String?

  administrations MedicationAdministration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedicationAdministration {
  id                    String                   @id @default(uuid())
  medicationOrder       AdmissionMedicationOrder @relation(fields: [medicationOrderId], references: [id])
  medicationOrderId     String
  admission             Admission                @relation(fields: [admissionId], references: [id])
  admissionId           String
  nurse                 Nurse                    @relation(fields: [administeredByNurseId], references: [id])
  administeredByNurseId String

  scheduledTime    DateTime
  actualTime       DateTime?
  status           MedicationAdminStatus
  reasonIfNotGiven String?
  remarks          String?

  createdAt DateTime @default(now())
}

model IVFluidOrder {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String

  orderedBy         Staff  @relation(fields: [orderedByDoctorId], references: [id])
  orderedByDoctorId String

  fluidType       String
  volume          Int
  rate            Int
  startTime       DateTime
  expectedEndTime DateTime
  status          IVOrderStatus @default(ACTIVE)

  monitorings IVMonitoring[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IVMonitoring {
  id          String       @id @default(uuid())
  ivOrder     IVFluidOrder @relation(fields: [ivOrderId], references: [id])
  ivOrderId   String
  admission   Admission    @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse        @relation(fields: [nurseId], references: [id])
  nurseId     String

  currentRate            Int
  insertionSiteCondition String
  complications          String?
  stoppedAt              DateTime?
  reasonStopped          String?

  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
}

model IntakeOutputRecord {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  type       IntakeOutputType
  category   IntakeOutputCategory
  amountMl   Int
  recordedAt DateTime
  notes      String?

  createdAt DateTime @default(now())
}

model NursingNote {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  noteType  NursingNoteType
  content   String
  createdAt DateTime        @default(now())
}

// Ward round (progress) notes for inpatients – SOAP-style, linked to admission and doctor
model WardRoundNote {
  id          String    @id @default(cuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  doctor      Staff     @relation(fields: [doctorId], references: [id])
  doctorId    String
  roundDate   DateTime // calendar day of the round (use date portion in queries)
  subjective  String?
  objective   String?
  assessment  String?
  plan        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([admissionId])
  @@index([doctorId])
  @@index([roundDate])
}

model ProcedureRecord {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  procedureType String
  description   String
  outcome       String?
  complications String?
  recordedAt    DateTime

  createdAt DateTime @default(now())
}

model WoundAssessment {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  woundLocation  String
  woundSize      String
  woundStage     String
  exudate        String
  odor           String
  infectionSigns String
  photoUrl       String?

  recordedAt DateTime @default(now())
}

model CarePlan {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  problem          String
  goal             String
  intervention     String
  evaluationStatus String

  updatedAt DateTime @updatedAt
}

model MonitoringChart {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  type       MonitoringChartType
  value      Json
  recordedAt DateTime
}

model HandoverReport {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String
  nurse       Nurse     @relation(fields: [nurseId], references: [id])
  nurseId     String

  shiftType ShiftType
  summary   String
  createdAt DateTime  @default(now())
}

model AlertLog {
  id          String    @id @default(uuid())
  admission   Admission @relation(fields: [admissionId], references: [id])
  admissionId String

  alertType    String
  severity     AlertSeverity
  message      String
  resolved     Boolean       @default(false)
  resolvedBy   Staff?        @relation(fields: [resolvedById], references: [id])
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
}

model AuditTrail {
  id            String          @id @default(uuid())
  entityName    String
  entityId      String
  actionType    AuditActionType
  performedBy   Staff           @relation(fields: [performedById], references: [id])
  performedById String
  performedAt   DateTime        @default(now())
  previousValue Json?
  newValue      Json?

  admission   Admission? @relation(fields: [admissionId], references: [id])
  admissionId String?
}

// ─────────────────────────────────────────────────────────────────────────────
// OBSTETRICS & GYNAECOLOGY MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Pregnancy {
  id          String          @id @default(uuid())
  patient     Patient         @relation(fields: [patientId], references: [id])
  patientId   String
  gravida     Int
  para        Int
  lmp         DateTime
  edd         DateTime
  bookingDate DateTime?
  status      PregnancyStatus @default(ONGOING)
  outcome     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   Staff   @relation("PregnancyCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("PregnancyUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  antenatalVisits  AntenatalVisit[]
  labourDeliveries LabourDelivery[] @relation("PregnancyLabourDeliveries")

  @@index([patientId])
  @@index([status])
}

model AntenatalVisit {
  id                 String             @id @default(uuid())
  pregnancy          Pregnancy          @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)
  pregnancyId        String
  visitDate          DateTime
  gestationWeeks     Float?
  systolicBP         Int?
  diastolicBP        Int?
  weight             Float?
  fundalHeight       Float?
  fetalHeartRate     Int?
  presentation       FetalPresentation?
  urineProtein       String?
  notes              String?
  ultrasoundFindings String?
  labResultsJson     Json?
  staff              Staff              @relation(fields: [staffId], references: [id])
  staffId            String
  encounter          Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  encounterId        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([pregnancyId])
  @@index([visitDate])
}

model LabourDelivery {
  id                String          @id @default(uuid())
  pregnancy         Pregnancy       @relation("PregnancyLabourDeliveries", fields: [pregnancyId], references: [id], onDelete: Cascade)
  pregnancyId       String
  admission         Admission?      @relation("AdmissionLabourDeliveries", fields: [admissionId], references: [id], onDelete: SetNull)
  admissionId       String?
  deliveryDateTime  DateTime
  mode              DeliveryMode
  outcome           DeliveryOutcome
  bloodLossMl       Int?
  placentaComplete  Boolean?
  episiotomy        Boolean?
  perinealTearGrade String?
  notes             String?
  deliveredBy       Staff           @relation(fields: [deliveredById], references: [id])
  deliveredById     String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  partogramEntries PartogramEntry[]
  babies           Baby[]
  postnatalVisits  PostnatalVisit[]

  @@index([pregnancyId])
  @@index([admissionId])
}

model PartogramEntry {
  id                   String         @id @default(uuid())
  labourDelivery       LabourDelivery @relation(fields: [labourDeliveryId], references: [id], onDelete: Cascade)
  labourDeliveryId     String
  recordedAt           DateTime
  cervicalDilationCm   Float?
  station              Int?
  contractionsPer10Min Int?
  fetalHeartRate       Int?
  moulding             String?
  descent              String?
  oxytocin             String?
  comments             String?
  recordedBy           Staff          @relation(fields: [recordedById], references: [id])
  recordedById         String
  createdAt            DateTime       @default(now())

  @@index([labourDeliveryId])
  @@index([recordedAt])
}

model Baby {
  id                  String         @id @default(uuid())
  labourDelivery      LabourDelivery @relation(fields: [labourDeliveryId], references: [id], onDelete: Cascade)
  labourDeliveryId    String
  mother              Patient        @relation(fields: [motherId], references: [id])
  motherId            String
  sex                 BabySex
  birthWeightG        Int?
  birthLengthCm       Float?
  apgar1              Int?
  apgar5              Int?
  resuscitation       String?
  birthOrder          Int            @default(1)
  registeredPatient   Patient?       @relation("BabyRegisteredPatient", fields: [registeredPatientId], references: [id], onDelete: SetNull)
  registeredPatientId String?        @unique
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  createdBy   Staff   @relation("BabyCreatedBy", fields: [createdById], references: [id])
  createdById String
  updatedBy   Staff?  @relation("BabyUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  postnatalVisits PostnatalVisit[]

  @@index([labourDeliveryId])
  @@index([motherId])
}

model PostnatalVisit {
  id                String             @id @default(uuid())
  labourDelivery    LabourDelivery     @relation(fields: [labourDeliveryId], references: [id], onDelete: Cascade)
  labourDeliveryId  String
  type              PostnatalVisitType
  visitDate         DateTime
  patient           Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)
  patientId         String?
  baby              Baby?              @relation(fields: [babyId], references: [id], onDelete: SetNull)
  babyId            String?
  uterusInvolution  String?
  lochia            String?
  perineum          String?
  bloodPressure     String?
  temperature       Float?
  breastfeeding     String?
  weight            Float?
  feeding           String?
  jaundice          String?
  immunisationGiven String?
  notes             String?
  staff             Staff              @relation(fields: [staffId], references: [id])
  staffId           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([labourDeliveryId])
  @@index([type])
  @@index([visitDate])
}

model GynaeProcedure {
  id            String     @id @default(uuid())
  patient       Patient    @relation(fields: [patientId], references: [id])
  patientId     String
  encounter     Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  encounterId   String?
  admission     Admission? @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  admissionId   String?
  procedureType String
  procedureDate DateTime
  surgeon       Staff      @relation("GynaeProcedureSurgeon", fields: [surgeonId], references: [id])
  surgeonId     String
  assistant     Staff?     @relation("GynaeProcedureAssistant", fields: [assistantId], references: [id], onDelete: SetNull)
  assistantId   String?
  findings      String?
  complications String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([patientId])
  @@index([procedureDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// RADIOLOGY MODULE
// ─────────────────────────────────────────────────────────────────────────────

model RadiologyMachine {
  id        String            @id @default(uuid())
  name      String
  modality  RadiologyModality
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  schedules  RadiologySchedule[]
  procedures RadiologyProcedure[]

  @@index([modality])
  @@index([isActive])
}

model RadiologyOrder {
  id            String                 @id @default(uuid())
  patient       Patient                @relation(fields: [patientId], references: [id])
  patientId     String
  encounter     Encounter?             @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  encounterId   String?
  requestedBy   Staff                  @relation("RadiologyOrderOrderedBy", fields: [requestedById], references: [id])
  requestedById String
  department    Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId  String?
  status        RadiologyRequestStatus @default(PENDING)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  items RadiologyOrderItem[]

  @@index([patientId])
  @@index([status])
  @@index([requestedById])
  @@index([createdAt])
}

model RadiologyOrderItem {
  id                     String                 @id @default(uuid())
  order                  RadiologyOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId                String
  clinicalNotes          String?
  reasonForInvestigation String?
  priority               RadiologyPriority      @default(ROUTINE)
  scanType               RadiologyModality
  bodyPart               String?
  status                 RadiologyRequestStatus @default(PENDING)
  invoiceItem            InvoiceItem?           @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  invoiceItemId          String?                @unique
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  schedule  RadiologySchedule?
  procedure RadiologyProcedure?
  images    RadiologyImage[]
  report    RadiologyStudyReport?

  @@index([orderId])
  @@index([status])
  @@index([priority])
  @@index([invoiceItemId])
}

model RadiologySchedule {
  id                   String             @id @default(uuid())
  radiologyOrderItem   RadiologyOrderItem @relation(fields: [radiologyOrderItemId], references: [id], onDelete: Cascade)
  radiologyOrderItemId String             @unique
  scheduledAt          DateTime
  radiographer         Staff?             @relation("RadiologyScheduleRadiographer", fields: [radiographerId], references: [id], onDelete: SetNull)
  radiographerId       String?
  machine              RadiologyMachine?  @relation(fields: [machineId], references: [id], onDelete: SetNull)
  machineId            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([scheduledAt])
  @@index([radiographerId])
  @@index([machineId])
}

model RadiologyProcedure {
  id                   String             @id @default(uuid())
  radiologyOrderItem   RadiologyOrderItem @relation(fields: [radiologyOrderItemId], references: [id], onDelete: Cascade)
  radiologyOrderItemId String             @unique
  performedBy          Staff              @relation("RadiologyProcedurePerformedBy", fields: [performedById], references: [id])
  performedById        String
  machine              RadiologyMachine?  @relation(fields: [machineId], references: [id], onDelete: SetNull)
  machineId            String?
  startTime            DateTime
  endTime              DateTime?
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([performedById])
  @@index([machineId])
}

model RadiologyImage {
  id                   String             @id @default(uuid())
  radiologyOrderItem   RadiologyOrderItem @relation(fields: [radiologyOrderItemId], references: [id], onDelete: Cascade)
  radiologyOrderItemId String
  fileName             String
  filePath             String
  mimeType             String?
  fileSize             Int?
  uploadedBy           Staff              @relation("RadiologyImageUploadedBy", fields: [uploadedById], references: [id])
  uploadedById         String
  uploadedAt           DateTime           @default(now())

  @@index([radiologyOrderItemId])
}

model RadiologyStudyReport {
  id                   String             @id @default(uuid())
  radiologyOrderItem   RadiologyOrderItem @relation(fields: [radiologyOrderItemId], references: [id], onDelete: Cascade)
  radiologyOrderItemId String             @unique
  findings             String?
  impression           String?
  recommendations      String?
  severity             ReportSeverity?
  signedBy             Staff              @relation("RadiologyReportSignedBy", fields: [signedById], references: [id])
  signedById           String
  signedAt             DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([signedById])
}

// ─────────────────────────────────────────────────────────────────────────────
// STORE MODULE (non-pharmacy / general supplies)
// ─────────────────────────────────────────────────────────────────────────────

enum StoreStockMovementType {
  ISSUE
  RECEIPT
  TRANSFER
  ADJUSTMENT
  RETURN
}

enum PurchaseNoteStatus {
  PENDING
  APPROVED
  REJECTED
  ORDERED
  COMPLETED
}

enum PurchaseNotePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model StoreItemCategory {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items StoreItem[]
}

model StoreItem {
  id            String            @id @default(uuid())
  name          String
  sku           String?           @unique
  category      StoreItemCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId    String
  unitOfMeasure String
  reorderLevel  Decimal           @default(0) @db.Decimal(12, 2)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  stocks            StoreStock[]
  movements         StoreStockMovement[]
  purchaseNoteItems PurchaseNoteItem[]

  @@index([categoryId])
  @@index([isActive])
}

model StoreLocation {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stocks        StoreStock[]
  movementsFrom StoreStockMovement[] @relation("StoreMovementFromLocation")
  movementsTo   StoreStockMovement[] @relation("StoreMovementToLocation")
}

model StoreStock {
  id             String        @id @default(uuid())
  item           StoreItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId         String
  location       StoreLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId     String
  quantity       Decimal       @default(0) @db.Decimal(12, 2)
  unitCost       Decimal       @default(0) @db.Decimal(12, 2)
  lastMovementAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([itemId, locationId])
  @@index([itemId])
  @@index([locationId])
}

model StoreStockMovement {
  id             String                 @id @default(uuid())
  item           StoreItem              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemId         String
  fromLocation   StoreLocation?         @relation("StoreMovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  fromLocationId String?
  toLocation     StoreLocation?         @relation("StoreMovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  toLocationId   String?
  department     Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId   String?
  type           StoreStockMovementType
  quantity       Decimal                @db.Decimal(12, 2)
  unitCost       Decimal                @db.Decimal(12, 2)
  totalCost      Decimal                @db.Decimal(12, 2)
  reason         String?
  referenceType  String?
  referenceId    String?
  createdBy      Staff                  @relation("StoreStockMovementCreatedBy", fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime               @default(now())

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([departmentId])
  @@index([type])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASES MODULE (purchase notes from departments)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseNote {
  id                     String             @id @default(uuid())
  requestingDepartment   Department         @relation(fields: [requestingDepartmentId], references: [id], onDelete: Restrict)
  requestingDepartmentId String
  requestedBy            Staff              @relation("PurchaseNoteRequestedBy", fields: [requestedById], references: [id])
  requestedById          String
  status                 PurchaseNoteStatus @default(PENDING)
  remarks                String?
  neededByDate           DateTime?
  totalEstimatedCost     Decimal            @default(0) @db.Decimal(12, 2)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  items PurchaseNoteItem[]

  @@index([requestingDepartmentId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseNoteItem {
  id                 String               @id @default(uuid())
  purchaseNote       PurchaseNote         @relation(fields: [purchaseNoteId], references: [id], onDelete: Cascade)
  purchaseNoteId     String
  storeItem          StoreItem?           @relation(fields: [storeItemId], references: [id], onDelete: SetNull)
  storeItemId        String?
  description        String
  quantity           Decimal              @db.Decimal(12, 2)
  estimatedUnitCost  Decimal?             @db.Decimal(12, 2)
  totalEstimatedCost Decimal?             @db.Decimal(12, 2)
  priority           PurchaseNotePriority @default(NORMAL)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([purchaseNoteId])
  @@index([storeItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// HELTY DESKTOP (Flutter Windows .exe distribution)
// ─────────────────────────────────────────────────────────────────────────────

model HeltyDesktopRelease {
  id           String   @id @default(uuid())
  /// Semantic version string shown to clients (e.g. 1.2.3)
  version      String   @unique
  /// Stored filename, e.g. helty1.2.3.exe
  fileName     String
  /// Path under uploads/helty-desktop/ (not the tmp folder)
  relativePath String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// Extra Windows .exe distribution files (besides the main Helty installer)
model HeltyDesktopExternalExecutable {
  id           String   @id @default(uuid())
  /// Stored filename, e.g. toolname.exe
  fileName     String   @unique
  /// Short human description shown in the UI
  description  String?
  /// Path under uploads/helty-desktop/ (not the tmp folder)
  relativePath String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
