# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/hospital_db"

# Redis: set USE_REDIS=true only when Redis is running. When not true, REDIS_URL is ignored and
# presence/unread are in-memory (single Nest process; no cross-instance Socket.IO).
USE_REDIS=false
REDIS_URL="redis://127.0.0.1:6379"

# Internal chat / uploads (LAN base for URLs returned to clients)
PUBLIC_API_BASE_URL=http://localhost:4000
PRESENCE_AWAY_MINUTES=5
PRESENCE_OFFLINE_AFTER_MINUTES=60
CHAT_MAX_FILE_BYTES=52428800
ALLOW_CHAT_GUEST=false

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration  
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Optional: Rate limiting
THROTTLE_LIMIT=10
THROTTLE_TTL=60

# Helty Flutter Windows desktop uploads (override in production)
HELITY_DESKTOP_UPLOAD_PASSWORD=vesselinc
